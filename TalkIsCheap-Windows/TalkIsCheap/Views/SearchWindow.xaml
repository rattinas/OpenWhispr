<Window x:Class="TalkIsCheap.Views.SearchWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="TalkIsCheap Search"
        Width="620" Height="500"
        WindowStartupLocation="CenterScreen"
        Topmost="True"
        ResizeMode="CanResize"
        KeyDown="Window_KeyDown">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Search bar header -->
        <Border Grid.Row="0" Background="#F8F8F8" Padding="16,12">
            <DockPanel>
                <Button DockPanel.Dock="Right" Content="X" Click="Close_Click"
                        Background="Transparent" BorderThickness="0" Foreground="Gray"
                        FontSize="14" Cursor="Hand" Padding="4,0"/>
                <Button DockPanel.Dock="Right" Content="Copy" Click="Copy_Click"
                        Margin="0,0,8,0" Padding="8,4" FontSize="11"/>
                <TextBlock x:Name="QueryText" FontSize="14" FontWeight="Medium"
                           VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
            </DockPanel>
        </Border>

        <!-- Answer content -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="20,16">
            <StackPanel>
                <TextBlock x:Name="AnswerText" TextWrapping="Wrap" FontSize="13"
                           LineHeight="22"/>
                <StackPanel x:Name="SourcesPanel" Margin="0,16,0,0"/>
            </StackPanel>
        </ScrollViewer>

        <!-- Footer -->
        <Border Grid.Row="2" Background="#F8F8F8" Padding="16,8">
            <TextBlock Text="Press Esc to close" Foreground="LightGray" FontSize="10"/>
        </Border>
    </Grid>
</Window>
