<Window x:Class="TalkIsCheap.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="TalkIsCheap Settings"
        Width="560" Height="520"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">

    <Window.Resources>
        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Margin" Value="0,12,0,6"/>
        </Style>
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="Margin" Value="0,6,0,3"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
        <Style x:Key="HintText" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Foreground" Value="Gray"/>
            <Setter Property="Margin" Value="0,2,0,0"/>
        </Style>
    </Window.Resources>

    <TabControl Margin="8">
        <!-- General Tab -->
        <TabItem Header="General">
            <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="12">
                <StackPanel>
                    <TextBlock Style="{StaticResource SectionHeader}" Text="Speech Recognition"/>
                    <TextBlock Style="{StaticResource FieldLabel}" Text="Engine"/>
                    <ComboBox x:Name="SttProviderCombo" SelectionChanged="SttProvider_Changed">
                        <ComboBoxItem Content="Groq Cloud (fast, recommended)" Tag="groq"/>
                        <ComboBoxItem Content="Local Whisper (not supported on Windows)" Tag="local" IsEnabled="False"/>
                    </ComboBox>

                    <TextBlock Style="{StaticResource FieldLabel}" Text="Language"/>
                    <ComboBox x:Name="LanguageCombo" SelectionChanged="Language_Changed"/>

                    <TextBlock Style="{StaticResource FieldLabel}" Text="Microphone"/>
                    <ComboBox x:Name="MicrophoneCombo" SelectionChanged="Microphone_Changed"/>
                    <TextBlock Style="{StaticResource HintText}" Text="Select which microphone to use for recording."/>

                    <TextBlock Style="{StaticResource SectionHeader}" Text="Text Polishing"/>
                    <TextBlock Style="{StaticResource FieldLabel}" Text="Engine"/>
                    <ComboBox x:Name="PolishProviderCombo" SelectionChanged="PolishProvider_Changed">
                        <ComboBoxItem Content="Anthropic Claude (recommended)" Tag="anthropic"/>
                        <ComboBoxItem Content="Ollama (local)" Tag="ollama"/>
                    </ComboBox>

                    <TextBlock Style="{StaticResource SectionHeader}" Text="Voice Search"/>
                    <TextBlock Style="{StaticResource FieldLabel}" Text="AI Model"/>
                    <ComboBox x:Name="SearchModelCombo" SelectionChanged="SearchModel_Changed">
                        <ComboBoxItem Content="Claude Opus 4.6 (best, slower)" Tag="claude-opus-4-6"/>
                        <ComboBoxItem Content="Claude Sonnet 4.6 (fast, recommended)" Tag="claude-sonnet-4-6"/>
                        <ComboBoxItem Content="Claude Haiku 4.5 (fastest, cheapest)" Tag="claude-haiku-4-5-20251001"/>
                    </ComboBox>

                    <TextBlock Style="{StaticResource SectionHeader}" Text="Hotkey"/>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <TextBlock Text="Current: " VerticalAlignment="Center"/>
                        <Border Background="#EAEAEA" CornerRadius="4" Padding="8,4">
                            <TextBlock x:Name="HotkeyDisplay" FontFamily="Consolas" Text="Ctrl"/>
                        </Border>
                        <Button x:Name="ChangeHotkeyBtn" Content="Change" Margin="8,0,0,0"
                                Click="ChangeHotkey_Click" Padding="8,4"/>
                    </StackPanel>
                    <TextBlock Style="{StaticResource HintText}" TextWrapping="Wrap">
                        Hold hotkey = dictate | Hold + Shift = hands-free | Double-tap = voice search
                    </TextBlock>
                    <TextBlock Style="{StaticResource HintText}" Text="Restart app after changing hotkey."/>
                </StackPanel>
            </ScrollViewer>
        </TabItem>

        <!-- API Keys Tab -->
        <TabItem Header="API Keys">
            <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="12">
                <StackPanel>
                    <TextBlock Style="{StaticResource SectionHeader}" Text="Groq (Speech Recognition)"/>
                    <TextBlock Style="{StaticResource FieldLabel}" Text="Groq API Key"/>
                    <PasswordBox x:Name="GroqKeyBox" PasswordChanged="GroqKey_Changed"/>
                    <TextBlock Style="{StaticResource HintText}">
                        <Hyperlink NavigateUri="https://console.groq.com/keys" RequestNavigate="Hyperlink_Navigate">
                            Get free key at console.groq.com
                        </Hyperlink>
                    </TextBlock>
                    <TextBlock Style="{StaticResource HintText}" Text="Free. Groq runs Whisper large-v3 for fast, accurate transcription."/>

                    <TextBlock Style="{StaticResource SectionHeader}" Text="Anthropic (Text Polishing)"/>
                    <TextBlock Style="{StaticResource FieldLabel}" Text="Anthropic API Key"/>
                    <PasswordBox x:Name="AnthropicKeyBox" PasswordChanged="AnthropicKey_Changed"/>
                    <TextBlock Style="{StaticResource HintText}">
                        <Hyperlink NavigateUri="https://console.anthropic.com/settings/keys" RequestNavigate="Hyperlink_Navigate">
                            Get key at console.anthropic.com
                        </Hyperlink>
                    </TextBlock>
                    <TextBlock Style="{StaticResource HintText}" Text="Claude Haiku -- fast and cheap (~$0.001/dictation)."/>

                    <TextBlock Style="{StaticResource SectionHeader}" Text="Brave Search (Voice Search)"/>
                    <TextBlock Style="{StaticResource FieldLabel}" Text="Brave Search API Key"/>
                    <PasswordBox x:Name="BraveKeyBox" PasswordChanged="BraveKey_Changed"/>
                    <TextBlock Style="{StaticResource HintText}">
                        <Hyperlink NavigateUri="https://brave.com/search/api/" RequestNavigate="Hyperlink_Navigate">
                            Get free key at brave.com/search/api
                        </Hyperlink>
                    </TextBlock>
                    <TextBlock Style="{StaticResource HintText}" Text="Free tier: 2000 searches/month. Double-tap your hotkey to ask anything."/>
                </StackPanel>
            </ScrollViewer>
        </TabItem>

        <!-- License Tab -->
        <TabItem Header="License">
            <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="12">
                <StackPanel>
                    <TextBlock Style="{StaticResource SectionHeader}" Text="License Status"/>
                    <StackPanel x:Name="LicenseStatusPanel"/>

                    <TextBlock Style="{StaticResource SectionHeader}" Text="Activate License" x:Name="ActivateHeader"/>
                    <TextBox x:Name="LicenseKeyBox" FontFamily="Consolas"
                             Text="" Margin="0,0,0,4"/>
                    <TextBlock Style="{StaticResource HintText}" Text="Format: TIC-XXXXX-XXXXX-XXXXX-XXXXX"/>
                    <Button x:Name="ActivateBtn" Content="Activate" Click="Activate_Click"
                            HorizontalAlignment="Left" Padding="16,6" Margin="0,8,0,0"/>
                    <TextBlock x:Name="ActivationMessage" Style="{StaticResource HintText}" Margin="0,4,0,0"/>

                    <Button x:Name="DeactivateBtn" Content="Deactivate this PC" Click="Deactivate_Click"
                            HorizontalAlignment="Left" Padding="16,6" Margin="0,12,0,0"
                            Foreground="Red" Visibility="Collapsed"/>

                    <Separator Margin="0,16,0,8"/>
                    <Button Content="Buy License -- $19 Lifetime" Click="Buy_Click"
                            HorizontalAlignment="Left" Padding="16,6"
                            Background="#FF8C00" Foreground="White" FontWeight="SemiBold"/>
                </StackPanel>
            </ScrollViewer>
        </TabItem>

        <!-- About Tab -->
        <TabItem Header="About">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Text="&#x1F3A4;" FontSize="48" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                <TextBlock Text="TalkIsCheap" FontSize="24" FontWeight="Bold" HorizontalAlignment="Center"/>
                <TextBlock Text="Version 2.0.0" Foreground="Gray" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                <TextBlock Text="Voice-to-text dictation for Windows" Foreground="Gray"
                           HorizontalAlignment="Center" Margin="0,8,0,16"/>
                <Separator Width="200" Margin="0,0,0,16"/>
                <TextBlock Text="Hold a key, speak, release." Foreground="Gray" HorizontalAlignment="Center"/>
                <TextBlock Text="Your words -- polished and pasted." Foreground="Gray" HorizontalAlignment="Center"/>
                <TextBlock Text="(c) 2026 TalkIsCheap" Foreground="LightGray" HorizontalAlignment="Center" Margin="0,24,0,0"/>
            </StackPanel>
        </TabItem>
    </TabControl>
</Window>
